# The default recipe
default: build

# Build the project
build:
    go build -tags goolm -o pan ./cmd/pan

run:
    go run -tags goolm ./cmd/pan

# Run tests
test:
    gotestsum --format testdox -- -tags goolm ./...

# Run tests and show coverage
coverage:
    gotestsum --format testdox -- -tags "goolm,e2e" -coverprofile=coverage.raw ./...
    grep -v "/mocks/" coverage.raw > coverage.out
    rm coverage.raw
    go tool cover -func=coverage.out

# Run E2E tests (hits local LLM model)
e2e-test:
    gotestsum --format testdox -- -tags "goolm,e2e" ./...

optimize agent:
    go run -tags goolm ./cmd/pan optimize {{ agent }}

# Watch for file changes, generate mocks, and run tests automatically
watch:
    watchexec -c -e go,yml "mockery && gotestsum --format testdox -- -tags goolm ./..."

# Start Jaeger locally via Docker with Dark Mode
jaeger:
    docker run -d --rm --name jaeger \
    	-p 16686:16686 \
    	-p 4317:4317 \
    	-p 4318:4318 \
    	-p 5778:5778 \
    	-p 9411:9411 \
    	jaegertracing/jaeger:latest

# Stop and remove the Jaeger container
jaeger-stop:
    docker stop jaeger || true

# Tidy Go modules
tidy:
    go mod tidy
